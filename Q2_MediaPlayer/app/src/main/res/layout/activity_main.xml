<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Title sabse upar app ka naam -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="Media Player"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- audio player ka title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Audio Player"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- ye button click karke audio file choose karenge device se -->
    <Button
        android:id="@+id/btnPickAudio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#1565C0"
        android:text="Pick Audio File" />

    <!-- ye dikhayega konsi file select ki hai -->
    <TextView
        android:id="@+id/tvAudioName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="No file selected"
        android:textSize="14sp" />

    <!-- Play, Pause, Stop, Restart buttons ek line mein horizontal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- play btn -->
        <ImageButton
            android:id="@+id/btnPlay"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play"
            android:src="@android:drawable/ic_media_play" />

        <!-- pause btn -->
        <ImageButton
            android:id="@+id/btnPause"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Pause"
            android:src="@android:drawable/ic_media_pause" />

        <!-- stop btn -->
        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Stop"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />

        <!-- restart btn — seekTo(0) se audio start se shuru hogi -->
        <ImageButton
            android:id="@+id/btnRestart"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Restart"
            android:src="@android:drawable/ic_media_previous" />

    </LinearLayout>

    <!-- video title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Video Player"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- URL type input field -->
    <EditText
        android:id="@+id/etVideoUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="Enter video URL"
        android:inputType="textUri" />

    <!-- ye button dabake video play hoga -->
    <Button
        android:id="@+id/btnPlayVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#1565C0"
        android:text="Play Video" />

    <!-- video area for viewing -->
    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="250dp" />

</LinearLayout>